## Kafka (KRaft) with SASL/PLAIN + ACLs
#
# Copy to `.env` and edit if needed.
#

# Confluent KRaft single-node settings
KAFKA_KRAFT_MODE=true
CLUSTER_ID=1L6g7nGhU-eAKfL--X25wo
KAFKA_NODE_ID=1
KAFKA_PROCESS_ROLES=broker,controller
KAFKA_CONTROLLER_QUORUM_VOTERS=1@kafka:9093
KAFKA_CONTROLLER_LISTENER_NAMES=CONTROLLER
KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR=1
KAFKA_LOG_DIRS=/tmp/kraft-combined-logs

# Listeners
# - Internal (Docker network): kafka:9092
# - External (host): localhost:9094
#   - When deploying on a server, set the *advertised* host/port to a real DNS name (e.g. kafka.interaims.com:443 if
#     fronted by a TCP TLS proxy, or kafka.interaims.com:9094 if you expose 9094 directly).
#   - If `docker compose ... up` fails with "address already in use" for the host port,
#     set `KA2A_KAFKA_HOST_PORT` (used by docker-compose.server.yml), e.g.:
#       KA2A_KAFKA_HOST_PORT=19094
#     and then point your TCP proxy upstream to `127.0.0.1:19094`.
#   - Examples:
#       # TLS proxy on :443 -> broker on localhost:9094
#       # KAFKA_ADVERTISED_LISTENERS=SASL_PLAINTEXT://kafka:9092,SASL_PLAINTEXT_PUBLIC://kafka.interaims.com:443
#       # Direct expose :9094 (not recommended without TLS)
#       # KAFKA_ADVERTISED_LISTENERS=SASL_PLAINTEXT://kafka:9092,SASL_PLAINTEXT_PUBLIC://kafka.interaims.com:9094
KAFKA_LISTENERS=SASL_PLAINTEXT://0.0.0.0:9092,SASL_PLAINTEXT_PUBLIC://0.0.0.0:9094,CONTROLLER://0.0.0.0:9093
KAFKA_ADVERTISED_LISTENERS=SASL_PLAINTEXT://kafka:9092,SASL_PLAINTEXT_PUBLIC://localhost:9094
KAFKA_LISTENER_SECURITY_PROTOCOL_MAP=SASL_PLAINTEXT:SASL_PLAINTEXT,SASL_PLAINTEXT_PUBLIC:SASL_PLAINTEXT,CONTROLLER:PLAINTEXT
KAFKA_INTER_BROKER_LISTENER_NAME=SASL_PLAINTEXT

# Optional: if you use KA2A_TOPIC_NAMESPACE in K-A2A, your topics will look like:
#   <namespace>.ka2a.req.<agent>, <namespace>.ka2a.reply.<clientId>, <namespace>.ka2a.agent_cards, ...
# In that case, set TOPIC_PREFIX to "<namespace>.ka2a" so the init script creates the right registry topic and ACLs.
# TOPIC_PREFIX=ka2a
# GROUP_PREFIX=ka2a

# SASL/PLAIN (static users)
KAFKA_SASL_ENABLED_MECHANISMS=PLAIN
KAFKA_SASL_MECHANISM_INTER_BROKER_PROTOCOL=PLAIN
KAFKA_LISTENER_NAME_SASL_PLAINTEXT_SASL_ENABLED_MECHANISMS=PLAIN
KAFKA_LISTENER_NAME_SASL_PLAINTEXT_PUBLIC_SASL_ENABLED_MECHANISMS=PLAIN

# IMPORTANT: change these defaults for any non-local use.
#
# admin user (superuser) + ka2a app user (for K-A2A)
KAFKA_LISTENER_NAME_SASL_PLAINTEXT_PLAIN_SASL_JAAS_CONFIG=org.apache.kafka.common.security.plain.PlainLoginModule required username="admin" password="admin-secret" user_admin="admin-secret" user_ka2a="ka2a-secret";
KAFKA_LISTENER_NAME_SASL_PLAINTEXT_PUBLIC_PLAIN_SASL_JAAS_CONFIG=org.apache.kafka.common.security.plain.PlainLoginModule required username="admin" password="admin-secret" user_admin="admin-secret" user_ka2a="ka2a-secret";

# ACLs (KRaft authorizer)
KAFKA_AUTHORIZER_CLASS_NAME=org.apache.kafka.metadata.authorizer.StandardAuthorizer
KAFKA_SUPER_USERS=User:admin
KAFKA_ALLOW_EVERYONE_IF_NO_ACL_FOUND=false
