NEXT_PUBLIC_PLATFORM_NAME=K-A2A Playground

# Used by RTK Query in the browser to call the FastAPI Gateway directly.
NEXT_PUBLIC_KA2A_GATEWAY_URL=http://localhost:8000

# Optional: browser-side timeout for direct gateway calls.
# Empty, 0, or any negative value disables the timeout.
# NEXT_PUBLIC_KA2A_REQUEST_TIMEOUT_MS=0
