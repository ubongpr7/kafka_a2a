## K-A2A configuration (example)
#
# Copy this file to `.env` and edit as needed.
#
# Required: Kafka bootstrap servers reachable from *inside the containers*.
KA2A_BOOTSTRAP_SERVERS=localhost:9092

# Optional: isolate multiple K-A2A deployments that share a Kafka cluster.
# If set, topic prefixes and the default registry/DLQ topics are automatically namespaced.
# KA2A_TOPIC_NAMESPACE=acme-dev
#
# Optional: override Kafka topic names/prefixes (advanced).
# KA2A_REQUESTS_PREFIX=ka2a.req
# KA2A_REPLIES_PREFIX=ka2a.reply
# KA2A_EVENTS_PREFIX=ka2a.evt
# KA2A_REGISTRY_TOPIC=ka2a.agent_cards

# Optional: set stable client IDs so reply topics are stable (useful if auto topic creation is disabled).
KA2A_GATEWAY_CLIENT_ID=gateway
KA2A_PROXY_CLIENT_ID=proxy
KA2A_ROUTER_CLIENT_ID=router

# Optional: used by the `prompted-echo` processor (host agent in docker-compose.yml).
KA2A_SYSTEM_PROMPT=You are the host agent. Replace this with your system prompt.

# Optional: Kafka security (SASL/TLS). Default is PLAINTEXT.
# KA2A_KAFKA_SECURITY_PROTOCOL=PLAINTEXT
#
# Example (server, Kafka behind a TCP TLS proxy like Caddy L4 on port 443):
# KA2A_BOOTSTRAP_SERVERS=kafka.interaims.com:443
# KA2A_KAFKA_SECURITY_PROTOCOL=SASL_SSL
# KA2A_KAFKA_SASL_MECHANISM=PLAIN
# KA2A_KAFKA_SASL_USERNAME=ka2a
# KA2A_KAFKA_SASL_PASSWORD=change-me
#
# SASL (when using SASL_PLAINTEXT or SASL_SSL):
# KA2A_KAFKA_SASL_MECHANISM=PLAIN
# KA2A_KAFKA_SASL_USERNAME=
# KA2A_KAFKA_SASL_PASSWORD=
# or KA2A_KAFKA_SASL_PASSWORD_ENV=OTHER_ENV_VAR_NAME
#
# TLS (when using SSL or SASL_SSL):
# KA2A_KAFKA_SSL_CA_FILE=/run/secrets/ca.pem
# KA2A_KAFKA_SSL_CERT_FILE=/run/secrets/client.pem
# KA2A_KAFKA_SSL_KEY_FILE=/run/secrets/client.key
# KA2A_KAFKA_SSL_KEY_PASSWORD=
# or KA2A_KAFKA_SSL_KEY_PASSWORD_ENV=OTHER_ENV_VAR_NAME
# KA2A_KAFKA_SSL_CHECK_HOSTNAME=true
# KA2A_KAFKA_SSL_INSECURE_SKIP_VERIFY=false

# Optional: dead-letter queue (DLQ) for malformed Kafka messages.
# KA2A_DLQ_ENABLED=false
# KA2A_DLQ_TOPIC=ka2a.dlq
# KA2A_DLQ_MAX_VALUE_BYTES=16384

# Optional: ops endpoints
# KA2A_METRICS_ENABLED=false
# KA2A_TRACE_ENABLED=false

# Optional: task store backend for agents (memory | redis).
# KA2A_TASK_STORE=memory

# Optional: Redis task store (requires `uv sync --extra redis` and KA2A_TASK_STORE=redis).
# KA2A_REDIS_URL=redis://localhost:6379/0
# KA2A_REDIS_NAMESPACE=ka2a
# KA2A_CONTEXT_HISTORY_TURNS=20

# Optional: LangGraph LLM processor (requires `uv sync --extra lang` and KA2A_AGENT_PROCESSOR=langgraph-chat).
# Default LLM factory is provider-based:
#   - Gemini -> kafka_a2a.llms.gemini:create_chat_model
#   - Otherwise -> kafka_a2a.llms.openai_compat:create_chat_model
# KA2A_LLM_CREDENTIALS_SOURCE=env
# KA2A_LLM_PROVIDER=gemini
# KA2A_LLM_MODEL=gemini-1.5-flash
# GOOGLE_API_KEY=your-api-key
#
# OpenAI-compatible example:
# KA2A_LLM_PROVIDER=openai_compat
# KA2A_LLM_BASE_URL=http://localhost:8002
# KA2A_LLM_MODEL=your-model
# KA2A_LLM_API_KEY=your-api-key
# KA2A_LLM_FACTORY=kafka_a2a.llms.openai_compat:create_chat_model  # optional override

# Optional: decryptor for JWT-embedded encrypted secrets (used when KA2A_LLM_CREDENTIALS_SOURCE=jwt).
# KA2A_SECRET_DECRYPTOR=your_pkg.crypto:decrypt_secret

# Optional: Tavily web search (used by the example weather/sports/finance agents).
# TAVILY_API_KEY=your-tavily-api-key
# KA2A_TAVILY_MAX_RESULTS=5
# KA2A_TAVILY_SEARCH_DEPTH=basic
# KA2A_TAVILY_TIMEOUT_S=30

# Optional: long-session memory (summary/profile) stored per context.
# - Store can be: off | memory | redis
# - Uses the same Redis as task store when store=redis.
# KA2A_CONTEXT_MEMORY_STORE=off
# KA2A_CONTEXT_MEMORY_SUMMARY=false
# KA2A_CONTEXT_MEMORY_PROFILE=false
# KA2A_CONTEXT_MEMORY_UPDATE_EVERY=1
# KA2A_CONTEXT_MEMORY_HISTORY_ITEMS=12
# KA2A_CONTEXT_MEMORY_MAX_SUMMARY_CHARS=1200
# KA2A_CONTEXT_MEMORY_TTL_S=0

# Optional: upstream LLM robustness
# KA2A_LLM_MAX_CONCURRENCY=5
# KA2A_LLM_RETRY_MAX_RETRIES=3
# KA2A_LLM_RETRY_BASE_DELAY_S=0.5
# KA2A_LLM_RETRY_MAX_DELAY_S=8

# Optional: JWT verification (gateway/proxy) for SaaS mode.
# - For RS256/ES256 with key rotation, prefer JWKS:
# KA2A_JWT_ENABLED=true
# KA2A_JWT_JWKS_URL=https://your-auth.example/.well-known/jwks.json
# KA2A_JWT_ALGORITHMS=RS256
# KA2A_JWT_AUDIENCE=your-audience
# KA2A_JWT_ISSUER=https://your-auth.example/
# KA2A_JWT_USER_CLAIM=sub
# KA2A_JWT_TENANT_CLAIM=tenant_id
# KA2A_JWT_INCLUDE_CLAIMS=true

# Optional: router processor (host agent orchestrates other agents).
# KA2A_AGENT_PROCESSOR=router
# KA2A_ROUTER_LLM_SELECTION=true
# KA2A_ROUTER_FALLBACK_AGENT=echo

# Optional: tool calling (MCP-ready) via the LangGraph processor.
# - Requires: KA2A_AGENT_PROCESSOR=langgraph-chat
# - For MCP HTTP tools: install `--extra mcp` and set:
# KA2A_TOOLS_ENABLED=false
# KA2A_TOOLS_SOURCE=mcp
# KA2A_TOOLS_MAX_STEPS=5
# KA2A_MCP_SERVER_URL=http://localhost:8005/mcp
# KA2A_MCP_TOKEN=
# KA2A_MCP_TIMEOUT_S=30
# KA2A_MCP_TOOLS_CACHE_S=60
