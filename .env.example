## K-A2A configuration (example)
#
# Copy this file to `.env` and edit as needed.
#
# Required: Kafka bootstrap servers reachable from *inside the containers*.
KA2A_BOOTSTRAP_SERVERS=localhost:9092

# Optional: set stable client IDs so reply topics are stable (useful if auto topic creation is disabled).
KA2A_GATEWAY_CLIENT_ID=gateway
KA2A_PROXY_CLIENT_ID=proxy

# Optional: used by the `prompted-echo` processor (host agent in docker-compose.yml).
KA2A_SYSTEM_PROMPT=You are the host agent. Replace this with your system prompt.

# Optional: task store backend for agents (memory | redis).
# KA2A_TASK_STORE=memory

# Optional: Redis task store (requires `uv sync --extra redis` and KA2A_TASK_STORE=redis).
# KA2A_REDIS_URL=redis://localhost:6379/0
# KA2A_REDIS_NAMESPACE=ka2a

# Optional: LangGraph LLM processor (requires `uv sync --extra lang` and KA2A_AGENT_PROCESSOR=langgraph-chat).
# Default LLM factory is provider-based:
#   - Gemini -> kafka_a2a.llms.gemini:create_chat_model
#   - Otherwise -> kafka_a2a.llms.openai_compat:create_chat_model
# KA2A_LLM_CREDENTIALS_SOURCE=env
# KA2A_LLM_PROVIDER=gemini
# KA2A_LLM_MODEL=gemini-1.5-flash
# GOOGLE_API_KEY=your-api-key
#
# OpenAI-compatible example:
# KA2A_LLM_PROVIDER=openai_compat
# KA2A_LLM_BASE_URL=http://localhost:8002
# KA2A_LLM_MODEL=your-model
# KA2A_LLM_API_KEY=your-api-key
# KA2A_LLM_FACTORY=kafka_a2a.llms.openai_compat:create_chat_model  # optional override

# Optional: decryptor for JWT-embedded encrypted secrets (used when KA2A_LLM_CREDENTIALS_SOURCE=jwt).
# KA2A_SECRET_DECRYPTOR=your_pkg.crypto:decrypt_secret
